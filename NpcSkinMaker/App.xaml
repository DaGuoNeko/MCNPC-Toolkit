<Application x:Class="NpcSkinMaker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ========== 主题色阶（仿 PCL2） ========== -->
            <Color x:Key="ColorObject1">#343D4A</Color>
            <Color x:Key="ColorObject2">#0B5BCB</Color>
            <Color x:Key="ColorObject3">#1370F3</Color>
            <Color x:Key="ColorObject4">#4890F5</Color>
            <Color x:Key="ColorObject5">#96C0F9</Color>
            <Color x:Key="ColorObject6">#D5E6FD</Color>
            <Color x:Key="ColorObject7">#E0EAFD</Color>
            <Color x:Key="ColorObject8">#EAF2FE</Color>

            <SolidColorBrush x:Key="ColorBrush1" Color="{StaticResource ColorObject1}" />
            <SolidColorBrush x:Key="ColorBrush2" Color="{StaticResource ColorObject2}" />
            <SolidColorBrush x:Key="ColorBrush3" Color="{StaticResource ColorObject3}" />
            <SolidColorBrush x:Key="ColorBrush4" Color="{StaticResource ColorObject4}" />
            <SolidColorBrush x:Key="ColorBrush5" Color="{StaticResource ColorObject5}" />
            <SolidColorBrush x:Key="ColorBrush6" Color="{StaticResource ColorObject6}" />
            <SolidColorBrush x:Key="ColorBrush7" Color="{StaticResource ColorObject7}" />
            <SolidColorBrush x:Key="ColorBrush8" Color="{StaticResource ColorObject8}" />

            <!-- ========== 灰阶 ========== -->
            <Color x:Key="ColorObjectGray1">#404040</Color>
            <Color x:Key="ColorObjectGray2">#737373</Color>
            <Color x:Key="ColorObjectGray3">#8C8C8C</Color>
            <Color x:Key="ColorObjectGray4">#A6A6A6</Color>
            <Color x:Key="ColorObjectGray5">#CCCCCC</Color>
            <Color x:Key="ColorObjectGray6">#EBEBEB</Color>
            <Color x:Key="ColorObjectGray7">#F0F0F0</Color>
            <Color x:Key="ColorObjectGray8">#F5F5F5</Color>

            <SolidColorBrush x:Key="ColorBrushGray1" Color="{StaticResource ColorObjectGray1}" />
            <SolidColorBrush x:Key="ColorBrushGray2" Color="{StaticResource ColorObjectGray2}" />
            <SolidColorBrush x:Key="ColorBrushGray3" Color="{StaticResource ColorObjectGray3}" />
            <SolidColorBrush x:Key="ColorBrushGray4" Color="{StaticResource ColorObjectGray4}" />
            <SolidColorBrush x:Key="ColorBrushGray5" Color="{StaticResource ColorObjectGray5}" />
            <SolidColorBrush x:Key="ColorBrushGray6" Color="{StaticResource ColorObjectGray6}" />
            <SolidColorBrush x:Key="ColorBrushGray7" Color="{StaticResource ColorObjectGray7}" />
            <SolidColorBrush x:Key="ColorBrushGray8" Color="{StaticResource ColorObjectGray8}" />

            <!-- ========== 语义色 ========== -->
            <Color x:Key="ColorObjectRedLight">#FF4C4C</Color>
            <Color x:Key="ColorObjectRedDark">#CE2111</Color>
            <Color x:Key="ColorObjectRedBack">#80FBDDDD</Color>
            <SolidColorBrush x:Key="ColorBrushRedLight" Color="{StaticResource ColorObjectRedLight}" />
            <SolidColorBrush x:Key="ColorBrushRedDark" Color="{StaticResource ColorObjectRedDark}" />
            <SolidColorBrush x:Key="ColorBrushRedBack" Color="{StaticResource ColorObjectRedBack}" />

            <SolidColorBrush x:Key="ColorBrushHalfWhite" Color="#55FFFFFF" />
            <SolidColorBrush x:Key="ColorBrushSemiWhite" Color="#BBFFFFFF" />
            <SolidColorBrush x:Key="ColorBrushWhite" Color="White" />
            <SolidColorBrush x:Key="ColorBrushTransparent" Color="Transparent" />
            <SolidColorBrush x:Key="ColorBrushSemiTransparent" Color="#01EAF2FE" />

            <!-- ========== 页面底色 ========== -->
            <SolidColorBrush x:Key="ColorBrushBackground" Color="#F5F5F5" />

            <!-- ========== Card Background (半透白色，改透明度只改这里) ========== -->
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#99FFFFFF" />

            <!-- ========== 字体 ========== -->
            <FontFamily x:Key="FontDefault">Microsoft YaHei UI, Microsoft YaHei</FontFamily>

            <!-- ========== 全局 TextBlock 样式 ========== -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontDefault}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
            </Style>

            <!-- ========== 可选文本样式（只读 TextBox，可选可复制） ========== -->
            <Style x:Key="SelectableText" TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource FontDefault}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray2}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="BorderBrush" Value="{x:Null}" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="CaretBrush" Value="{DynamicResource ColorBrush3}" />
                <Setter Property="SelectionBrush" Value="{DynamicResource ColorBrush5}" />
                <Setter Property="Focusable" Value="True" />
                <Setter Property="Cursor" Value="IBeam" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!-- ========== 全局 Label 样式 ========== -->
            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontDefault}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!-- ========== 滚动条样式 ========== -->
            <Style x:Key="MyThumb" TargetType="Thumb">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent">
                                <Border Background="{DynamicResource ColorBrush4}"
                                        CornerRadius="2"
                                        Margin="2"
                                        Opacity="0.7" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MyScrollBar" TargetType="ScrollBar">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Width" Value="8" />
                <Setter Property="MinWidth" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent" CornerRadius="2">
                                <Track Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource MyThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar" BasedOn="{StaticResource MyScrollBar}" />

            <!-- ========== 滚动视图样式 ========== -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollViewer">
                            <Grid>
                                <ScrollContentPresenter Margin="0,0,8,0" />
                                <ScrollBar Name="PART_VerticalScrollBar"
                                           HorizontalAlignment="Right"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                                <ScrollBar Name="PART_HorizontalScrollBar"
                                           VerticalAlignment="Bottom"
                                           Orientation="Horizontal"
                                           Value="{TemplateBinding HorizontalOffset}"
                                           Maximum="{TemplateBinding ScrollableWidth}"
                                           ViewportSize="{TemplateBinding ViewportWidth}"
                                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ========== TabControl 样式（PCL2 风格） ========== -->
            <Style TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <!-- ========== TabItem 样式（PCL2 风格：扁平圆角标签） ========== -->
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource ColorBrushGray2}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="{StaticResource FontDefault}" />
                <Setter Property="Padding" Value="14,5" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="PanBack" CornerRadius="3" Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                <ContentPresenter x:Name="ContentSite" ContentSource="Header"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="PanBack" Property="Background" Value="{DynamicResource ColorBrush7}" />
                                    <Setter Property="Foreground" Value="{DynamicResource ColorBrush2}" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="False">
                                    <Setter Property="FontWeight" Value="Normal" />
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="PanBack" Property="Background" Value="{DynamicResource ColorBrushGray7}" />
                                    <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ========== CheckBox 样式（PCL2 风格） ========== -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource ColorBrush1}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="{StaticResource FontDefault}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="Box" Width="18" Height="18" CornerRadius="3"
                                        BorderThickness="1.5"
                                        BorderBrush="{DynamicResource ColorBrushGray4}"
                                        Background="{DynamicResource ColorBrushHalfWhite}"
                                        VerticalAlignment="Center">
                                    <Path x:Name="Check" Width="10" Height="10" Stretch="Uniform"
                                          Fill="White" Data="F1 M0,5 L4,9 11,1 9,0 4,6 2,4 0,5 Z"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ColorBrush3}" />
                                    <Setter TargetName="Box" Property="Background" Value="{DynamicResource ColorBrush3}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource ColorBrush4}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
