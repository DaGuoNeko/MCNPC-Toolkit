<UserControl x:Class="NpcSkinMaker.LogoIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- 方块 -->
        <Path x:Name="Root" Grid.Row="0"
              Stroke="White" Fill="#22FFFFFF"
              StrokeThickness="1.2" StrokeLineJoin="Round"
              Stretch="Uniform"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <TransformGroup>
                    <TranslateTransform x:Name="FloatTransform" Y="0" />
                    <RotateTransform x:Name="RotateTransform" Angle="0" />
                </TransformGroup>
            </Path.RenderTransform>
            <Path.Data>
                <GeometryGroup>
                    <PathGeometry Figures="M8,0 L16,5 L8,10 L0,5 Z" />
                    <PathGeometry Figures="M0,5 L0,13 L8,18 L8,10 Z" />
                    <PathGeometry Figures="M16,5 L16,13 L8,18 L8,10 Z" />
                    <PathGeometry Figures="M4,5 L12,5 M8,0 L8,10" />
                    <PathGeometry Figures="M0,9 L8,14 M4,7 L4,15" />
                    <PathGeometry Figures="M16,9 L8,14 M12,7 L12,15" />
                </GeometryGroup>
            </Path.Data>
        </Path>
        <!-- 地面影子（黑色渐变） -->
        <Ellipse x:Name="Shadow" Grid.Row="1" Width="12" Height="3"
                 HorizontalAlignment="Center" VerticalAlignment="Top">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#33000000" Offset="0" />
                    <GradientStop Color="#00000000" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
    </Grid>
</UserControl>
