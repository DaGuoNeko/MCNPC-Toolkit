<Border x:Class="NpcSkinMaker.MyButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        CornerRadius="5"
        BorderThickness="1"
        Background="{DynamicResource ColorBrushHalfWhite}"
        BorderBrush="{DynamicResource ColorBrush1}"
        Padding="14,6"
        Cursor="Hand"
        RenderTransformOrigin="0.5,0.5">
    <Border.RenderTransform>
        <ScaleTransform x:Name="ScaleTrans" ScaleX="1" ScaleY="1" />
    </Border.RenderTransform>
    <Border x:Name="PanFore"
            CornerRadius="5"
            BorderThickness="1"
            Background="Transparent"
            BorderBrush="Transparent">
        <TextBlock x:Name="LabText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="13"
                   TextOptions.TextFormattingMode="Ideal"
                   Foreground="{DynamicResource ColorBrush1}" />
    </Border>
</Border>
