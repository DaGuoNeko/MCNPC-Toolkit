<UserControl x:Class="NpcSkinMaker.MyCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="7"
            Background="White"
            BorderThickness="1"
            BorderBrush="{DynamicResource ColorBrushGray5}"
            Padding="16,12"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="TransTrans" X="0" Y="0" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="ShadowEffect"
                              Color="{DynamicResource ColorObject4}"
                              BlurRadius="10"
                              ShadowDepth="0"
                              Opacity="0.08"
                              Direction="270" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="LabTitle"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource ColorBrush1}"
                       Margin="0,0,0,8" />
            <ContentPresenter x:Name="MainContent" />
        </StackPanel>
    </Border>
</UserControl>
