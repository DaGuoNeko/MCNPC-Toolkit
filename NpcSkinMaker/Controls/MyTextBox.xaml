<Border x:Class="NpcSkinMaker.MyTextBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        CornerRadius="5"
        BorderThickness="1"
        Background="{DynamicResource ColorBrushHalfWhite}"
        BorderBrush="{DynamicResource ColorBrushGray4}"
        Padding="8,4"
        MinHeight="30">
    <Grid>
        <TextBlock x:Name="LabHint"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource ColorBrushGray3}"
                   FontSize="13"
                   IsHitTestVisible="False"
                   Visibility="Collapsed" />
        <TextBox x:Name="InnerBox"
                 BorderThickness="0"
                 Background="Transparent"
                 FontSize="13"
                 Foreground="{DynamicResource ColorBrush1}"
                 VerticalAlignment="Center"
                 CaretBrush="{DynamicResource ColorBrush3}"
                 SelectionBrush="{DynamicResource ColorBrush5}" />
    </Grid>
</Border>
