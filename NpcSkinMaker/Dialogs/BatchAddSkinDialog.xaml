<Window x:Class="NpcSkinMaker.BatchAddSkinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NpcSkinMaker"
        Title="批量添加皮肤" Width="680" Height="560"
        WindowStyle="None" AllowsTransparency="True"
        Background="{x:Null}" WindowStartupLocation="CenterOwner">
    <Border Margin="8" Background="#FBFBFB" CornerRadius="7">
        <Border.Effect>
            <DropShadowEffect Color="#343D4A" BlurRadius="20" ShadowDepth="4" Opacity="0.25" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题区 -->
            <StackPanel Grid.Row="0" Margin="22,18,22,0">
                <Grid>
                    <TextBlock x:Name="LabTitle" Text="批量添加皮肤" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush2}" Margin="0,-1,40,0" />
                    <local:MyIconButton x:Name="BtnClose" Logo="{x:Static local:MyIconButton.IconClose}"
                                        Theme="Color" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Width="28" Height="28" />
                </Grid>
                <Rectangle Height="2" Fill="{DynamicResource ColorBrush2}" Margin="0,8,0,0" />
            </StackPanel>

            <!-- 内容区 -->
            <StackPanel Grid.Row="1" Margin="22,16,22,8">
                <TextBlock Text="选择多个 PNG 贴图文件，将自动使用文件名作为人物名称"
                           FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,10" />

                <TextBlock Text="已选择的贴图文件:" FontSize="13" Margin="0,0,0,4" />
                <Border BorderBrush="{DynamicResource ColorBrushGray5}" BorderThickness="1" CornerRadius="3"
                        Margin="0,0,0,9" Height="240">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanFileList" />
                    </ScrollViewer>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="统一作者" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,0" />
                    <local:MyTextBox x:Name="TxtAuthor" Grid.Column="1" Hint="输入作者名称（所有皮肤使用相同作者）..." VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="22,0,22,16">
                <local:MyButton x:Name="BtnSelect" Text="选择文件" Margin="0,0,12,0" Padding="13,4" />
                <local:MyButton x:Name="BtnClear" Text="清空列表" Margin="0,0,12,0" Padding="13,4" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <local:MyButton x:Name="BtnConfirm" Text="确认添加" ColorType="Highlight" Margin="0,0,12,0" Padding="20,4" MinWidth="100" />
                    <local:MyButton x:Name="BtnCancel" Text="取消" Padding="20,4" MinWidth="100" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
