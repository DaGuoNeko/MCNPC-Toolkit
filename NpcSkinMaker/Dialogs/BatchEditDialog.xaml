<Window x:Class="NpcSkinMaker.BatchEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NpcSkinMaker"
        Title="批量编辑皮肤" Width="500" Height="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="{x:Null}" WindowStartupLocation="CenterOwner">
    <Border Margin="8" Background="#FBFBFB" CornerRadius="7">
        <Border.Effect>
            <DropShadowEffect Color="#343D4A" BlurRadius="20" ShadowDepth="4" Opacity="0.25" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题区 -->
            <StackPanel Grid.Row="0" Margin="22,18,22,0">
                <Grid>
                    <TextBlock x:Name="LabTitle" Text="批量编辑皮肤" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush2}" Margin="0,-1,40,0" />
                    <local:MyIconButton x:Name="BtnClose" Logo="{x:Static local:MyIconButton.IconClose}"
                                        Theme="Color" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Width="28" Height="28" />
                </Grid>
                <Rectangle Height="2" Fill="{DynamicResource ColorBrush2}" Margin="0,8,0,0" />
            </StackPanel>

            <!-- 内容区 -->
            <StackPanel Grid.Row="1" Margin="22,16,22,8">
                <TextBlock Text="批量修改选中皮肤的人物名称和作者。留空表示不修改该字段。"
                           FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,12" TextWrapping="Wrap" />
                <Grid Margin="0,0,0,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="统一人物名称" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,0" />
                    <local:MyTextBox x:Name="TxtName" Grid.Column="1" Hint="留空表示不修改..." VerticalAlignment="Center" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="统一作者名称" VerticalAlignment="Center" FontSize="13" Margin="0,0,15,0" />
                    <local:MyTextBox x:Name="TxtAuthor" Grid.Column="1" Hint="留空表示不修改..." VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="22,0,22,16">
                <local:MyButton x:Name="BtnConfirm" Text="确认修改" ColorType="Highlight" Margin="0,0,12,0" Padding="20,4" MinWidth="100" />
                <local:MyButton x:Name="BtnCancel" Text="取消" Padding="20,4" MinWidth="100" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
