<Window x:Class="NpcSkinMaker.PreviewSkinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NpcSkinMaker"
        Title="预览皮肤" Width="540" Height="600"
        WindowStyle="None" AllowsTransparency="True"
        Background="{x:Null}" WindowStartupLocation="CenterOwner">
    <Border Margin="8" Background="#FBFBFB" CornerRadius="7">
        <Border.Effect>
            <DropShadowEffect Color="#343D4A" BlurRadius="20" ShadowDepth="4" Opacity="0.25" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题区 -->
            <StackPanel Grid.Row="0" Margin="22,18,22,0">
                <Grid>
                    <TextBlock x:Name="LabTitle" Text="预览皮肤" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush2}" Margin="0,-1,40,0" />
                    <local:MyIconButton x:Name="BtnClose" Logo="{x:Static local:MyIconButton.IconClose}"
                                        Theme="Color" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Width="28" Height="28" />
                </Grid>
                <Rectangle Height="2" Fill="{DynamicResource ColorBrush2}" Margin="0,8,0,0" />
            </StackPanel>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="22,16,22,8">
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock x:Name="LabName" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock x:Name="LabAuthor" FontSize="13" Foreground="{DynamicResource ColorBrushGray2}" />
                    </StackPanel>
                    <Border Background="{DynamicResource ColorBrushGray7}" CornerRadius="3" Padding="16"
                            MinHeight="200">
                        <Image x:Name="ImgPreview" Stretch="Uniform" MaxWidth="460" MaxHeight="400" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="22,0,22,16">
                <local:MyButton x:Name="BtnCloseBottom" Text="关闭" Padding="20,4" MinWidth="100" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
