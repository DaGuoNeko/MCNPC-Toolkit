<Window x:Class="NpcSkinMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NpcSkinMaker"
        Title="MCNPC 拓展制作工具箱"
        Width="1100" Height="619"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="{x:Null}"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">

    <!-- 外层透明边距（缩放手柄区域） -->
    <Grid x:Name="PanMain" Margin="10" Background="#01000000">
        <Grid.Effect>
            <DropShadowEffect Color="#343D4A" BlurRadius="20" ShadowDepth="0" Opacity="0.35" />
        </Grid.Effect>

        <Grid.RenderTransform>
            <TransformGroup>
                <RotateTransform x:Name="TransformRotate" Angle="-4" />
                <TranslateTransform x:Name="TransformPos" Y="60" />
            </TransformGroup>
        </Grid.RenderTransform>

        <!-- ===== 缩放手柄（8 个渐变矩形） ===== -->
        <Rectangle x:Name="ResizerL" Width="8" HorizontalAlignment="Left" Fill="#01000000" Cursor="SizeWE" />
        <Rectangle x:Name="ResizerR" Width="8" HorizontalAlignment="Right" Fill="#01000000" Cursor="SizeWE" />
        <Rectangle x:Name="ResizerT" Height="8" VerticalAlignment="Top" Fill="#01000000" Cursor="SizeNS" />
        <Rectangle x:Name="ResizerB" Height="8" VerticalAlignment="Bottom" Fill="#01000000" Cursor="SizeNS" />
        <Rectangle x:Name="ResizerLT" Width="13" Height="13" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#01000000" Cursor="SizeNWSE" />
        <Rectangle x:Name="ResizerLB" Width="13" Height="13" HorizontalAlignment="Left" VerticalAlignment="Bottom" Fill="#01000000" Cursor="SizeNESW" />
        <Rectangle x:Name="ResizerRT" Width="13" Height="13" HorizontalAlignment="Right" VerticalAlignment="Top" Fill="#01000000" Cursor="SizeNESW" />
        <Rectangle x:Name="ResizerRB" Width="13" Height="13" HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#01000000" Cursor="SizeNWSE" />

        <!-- ===== 主窗口内容 ===== -->
        <Border x:Name="BorderForm" Margin="8" Background="{DynamicResource ColorBrushBackground}" CornerRadius="6">
            <Border.Clip>
                <RectangleGeometry x:Name="RectForm" RadiusX="6" RadiusY="6" />
            </Border.Clip>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 自定义背景图（垫在内容下面） -->
                <Image x:Name="ImgBackground" Grid.RowSpan="2" Stretch="UniformToFill"
                       Opacity="0.7" IsHitTestVisible="False" />

                <!-- ===== 标题栏 ===== -->
                <Border x:Name="PanTitle" Grid.Row="0" Background="{DynamicResource ColorBrush2}" CornerRadius="6,6,0,0">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Logo + 标题 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <local:LogoIcon Width="20" Height="24" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="MCNPC 拓展制作工具箱" Foreground="White" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" FontFamily="{DynamicResource FontDefault}" />
                        </StackPanel>

                        <!-- 功能切换栏（嵌在标题栏中间） -->
                        <StackPanel x:Name="PanTopTabs" Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- 标题栏按钮 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <local:MyIconButton x:Name="BtnMin" Logo="{x:Static local:MyIconButton.IconMinimize}"
                                                Theme="White" Width="36" Height="32" Margin="0,0,4,0" />
                            <local:MyIconButton x:Name="BtnMax" Logo="{x:Static local:MyIconButton.IconMaximize}"
                                                Theme="White" Width="36" Height="32" Margin="0,0,4,0" />
                            <local:MyIconButton x:Name="BtnClose" Logo="{x:Static local:MyIconButton.IconClose}"
                                                Theme="White" Width="36" Height="32" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== 主内容区 ===== -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧导航栏 -->
                    <Border x:Name="PanMainLeft" Grid.Column="0" Background="#E6FFFFFF" BorderBrush="{DynamicResource ColorBrushGray5}" BorderThickness="0,0,1,0">
                        <StackPanel x:Name="PanLeftItems" Margin="8,12,8,12" />
                    </Border>

                    <!-- 右侧内容区 -->
                    <Border x:Name="PanMainRight" Grid.Column="1" Background="Transparent">
                        <Grid x:Name="PanRightContent" Margin="3,3,3,0" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
