<UserControl x:Class="NpcSkinMaker.PageMcStudioConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent">

            <!-- ===== 卡片1：MCStudio 路径 & 账号 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource ColorBrushGray5}"
                    Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="MCStudio 路径 &amp; 账号" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <!-- 下载根目录 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="下载根目录:" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <local:MyTextBox x:Name="TxtRootPath" Grid.Column="1" Hint="自动检测中..."
                                         VerticalAlignment="Center" Margin="8,0" />
                    </Grid>

                    <!-- 账号选择 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MCStudio账号:" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource ColorBrush1}" />
                        <ComboBox x:Name="CmbAccount" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                  FontSize="13" FontFamily="{DynamicResource FontDefault}" />
                        <local:MyButton x:Name="BtnRefresh" Grid.Column="2" Text="刷新" VerticalAlignment="Center"
                                        Padding="13,4" />
                    </Grid>

                    <!-- 打开配置文件夹 -->
                    <local:MyButton x:Name="BtnOpenConfigDir" Text="打开当前配置列表文件夹"
                                    HorizontalAlignment="Left" Padding="16,6" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- ===== 卡片2：项目列表 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}"
                    BorderThickness="1" BorderBrush="{DynamicResource ColorBrushGray5}"
                    Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="项目列表" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <!-- 搜索框 + 计数 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TxtSearch" Grid.Column="0" Hint="搜索项目名称..."
                                         VerticalAlignment="Center" />
                        <TextBlock x:Name="LabCount" Grid.Column="1" Text="共 0 个项目" FontSize="12"
                                   Foreground="{DynamicResource ColorBrushGray2}" VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </Grid>

                    <!-- 项目列表容器 -->
                    <ScrollViewer x:Name="ScrollProjects" MaxHeight="480" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanProjectList" />
                    </ScrollViewer>

                    <!-- 空状态提示 -->
                    <TextBlock x:Name="LabEmpty" Text="请先选择 MCStudio 账号" FontSize="13"
                               Foreground="{DynamicResource ColorBrushGray3}" HorizontalAlignment="Center"
                               Margin="0,16,0,0" Visibility="Visible" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
