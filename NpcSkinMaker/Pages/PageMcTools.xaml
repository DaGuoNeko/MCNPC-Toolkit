<UserControl x:Class="NpcSkinMaker.PageMcTools"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent" HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="300">
            <TextBlock Text="MC 工具箱" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource ColorBrushGray3}" Margin="0,0,0,8" />
            <TextBlock Text="功能即将上线" FontSize="13"
                       Foreground="{DynamicResource ColorBrushGray4}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
