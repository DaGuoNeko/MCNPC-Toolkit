<UserControl x:Class="NpcSkinMaker.PageMcTools"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent">

            <!-- 启动 MC -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="启动网易开发版互通 MC" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="游戏路径:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtMcPath" Grid.Column="1" Hint="选择 MC 启动器 exe 文件..." VerticalAlignment="Center" Margin="8,0" />
                        <local:MyButton x:Name="BtnBrowseMc" Grid.Column="2" Text="浏览" VerticalAlignment="Center" Padding="13,4" />
                    </Grid>

                    <local:MyButton x:Name="BtnLaunchMc" Text="启动网易开发版互通 MC" ColorType="Highlight"
                                    HorizontalAlignment="Left" Padding="24,6" />
                </StackPanel>
            </Border>

            <!-- 一键生成 MOD 框架 -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="一键生成 Minecraft 网易版模组完整框架" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="脚本路径:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtScriptPath" Grid.Column="1" Hint="选择一键生成完整MOD.py..." VerticalAlignment="Center" Margin="8,0" />
                        <local:MyButton x:Name="BtnBrowseScript" Grid.Column="2" Text="浏览" VerticalAlignment="Center" Padding="13,4" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="模组名称:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtModName" Grid.Column="1" Hint="仅限字母、数字、下划线..." VerticalAlignment="Center" Margin="8,0" />
                    </Grid>

                    <!-- 可选功能 -->
                    <WrapPanel Margin="0,0,0,8">
                        <CheckBox x:Name="ChkHelp" Content="帮助页面" FontSize="13" Margin="0,0,16,4" />
                        <CheckBox x:Name="ChkHud" Content="HUD 覆盖层" FontSize="13" Margin="0,0,16,4" />
                        <CheckBox x:Name="ChkWorldData" Content="跨存档数据" FontSize="13" Margin="0,0,16,4" />
                        <CheckBox x:Name="ChkSetting" Content="设置页面" FontSize="13" Margin="0,0,16,4" />
                    </WrapPanel>

                    <local:MyButton x:Name="BtnGenMod" Text="生成 MOD 框架" ColorType="Highlight"
                                    HorizontalAlignment="Left" Padding="24,6" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
