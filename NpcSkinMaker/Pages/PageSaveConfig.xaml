<UserControl x:Class="NpcSkinMaker.PageSaveConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent">

            <!-- ===== 卡片1：路径 & 玩家 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="网易互通版存档全局配置列表" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <!-- 游戏路径 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="游戏路径:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtFeverGamePath" Grid.Column="1" Hint="自动检测中..." VerticalAlignment="Center" Margin="8,0" />
                        <local:MyButton x:Name="BtnRefresh" Grid.Column="2" Text="刷新" VerticalAlignment="Center" Padding="13,4" />
                    </Grid>

                    <!-- 端选择 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="选择端:" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox x:Name="CmbChannel" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                  FontSize="13" FontFamily="{DynamicResource FontDefault}" />
                    </Grid>

                    <!-- 玩家ID -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="玩家ID:" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox x:Name="CmbPlayerId" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                  FontSize="13" FontFamily="{DynamicResource FontDefault}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 卡片2：文件列表 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <!-- 搜索 + 计数 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TxtSearch" Grid.Column="0" Hint="搜索文件名..." VerticalAlignment="Center" />
                        <TextBlock x:Name="LabCount" Grid.Column="1" Text="共 0 个文件" FontSize="12"
                                   Foreground="{DynamicResource ColorBrushGray2}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <!-- 文件列表 -->
                    <ScrollViewer x:Name="ScrollFiles" MaxHeight="480" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanFileList" />
                    </ScrollViewer>

                    <!-- 空状态 -->
                    <TextBlock x:Name="LabEmpty" Text="请先选择玩家 ID" FontSize="13"
                               Foreground="{DynamicResource ColorBrushGray3}" HorizontalAlignment="Center"
                               Margin="0,12,0,0" Visibility="Visible" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
