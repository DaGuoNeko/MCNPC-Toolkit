<UserControl x:Class="NpcSkinMaker.PageSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent">

            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="常规设置" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />
                    <!-- 默认输出目录 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="默认输出目录:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtOutputDir" Grid.Column="1" Hint="选择默认导出目录..." VerticalAlignment="Center" Margin="8,0" />
                        <local:MyButton x:Name="BtnBrowseDir" Grid.Column="2" Text="浏览" VerticalAlignment="Center" />
                    </Grid>
                    <!-- 背景图片 -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="背景图片:" VerticalAlignment="Center" FontSize="13" />
                        <local:MyTextBox x:Name="TxtBgImage" Grid.Column="1" Hint="选择自定义背景图片..." VerticalAlignment="Center" Margin="8,0" />
                        <local:MyButton x:Name="BtnBrowseBg" Grid.Column="2" Text="浏览" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <local:MyButton x:Name="BtnClearBg" Grid.Column="3" Text="清除" ColorType="Red" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="主题设置" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <CheckBox x:Name="ChkSystemAccent" Content="跟随系统主题色" FontSize="13"
                              Margin="0,0,0,12" Checked="ChkSystemAccent_Changed" Unchecked="ChkSystemAccent_Changed" />

                    <TextBlock Text="主题色相 (Hue: 0-360)" FontSize="13" Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <local:MySlider x:Name="SliderHue" MaxValue="360" Width="300" VerticalAlignment="Center" />
                        <TextBlock x:Name="LabHue" Text="210" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="主题饱和度 (Saturation: 0-100)" FontSize="13" Margin="0,0,0,6" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <local:MySlider x:Name="SliderSat" MaxValue="100" Width="300" VerticalAlignment="Center" />
                        <TextBlock x:Name="LabSat" Text="85" FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- 预设颜色 -->
                    <TextBlock Text="预设主题:" FontSize="13" Margin="0,8,0,8" />
                    <WrapPanel x:Name="PanThemes" />
                </StackPanel>
            </Border>

            <!-- ===== 字体设置 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="字体设置" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource ColorBrush1}" Margin="0,0,0,8" />

                    <!-- 系统字体下拉 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="系统字体:" VerticalAlignment="Center" FontSize="13" />
                        <ComboBox x:Name="CmbFont" Grid.Column="1" VerticalAlignment="Center" Margin="8,0"
                                  FontSize="13" />
                        <local:MyButton x:Name="BtnBrowseFont" Grid.Column="2" Text="选择字体文件"
                                        VerticalAlignment="Center" Padding="13,4" />
                    </Grid>

                    <!-- 预览 -->
                    <TextBlock x:Name="LabFontPreview" Text="字体预览: AaBbCc 中文预览 0123456789"
                               FontSize="15" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
