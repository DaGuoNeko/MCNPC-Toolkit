<UserControl x:Class="NpcSkinMaker.PageTestSaves"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NpcSkinMaker"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,6">
        <StackPanel x:Name="PanContent">

            <!-- ===== 卡片1：项目信息 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <local:MyButton x:Name="BtnBack" Grid.Column="0" Text="← 返回" VerticalAlignment="Center"
                                        Padding="12,5" ColorType="Normal" />
                        <TextBlock x:Name="LabTitle" Grid.Column="1" Text="测试存档列表" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource ColorBrush1}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                    <TextBlock x:Name="LabProjectInfo" Text="" FontSize="13"
                               Foreground="{DynamicResource ColorBrushGray2}" />
                </StackPanel>
            </Border>

            <!-- ===== 卡片2：存档列表 ===== -->
            <Border CornerRadius="7" Background="{DynamicResource CardBackgroundBrush}" BorderThickness="1"
                    BorderBrush="{DynamicResource ColorBrushGray5}" Padding="16,12" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource ColorObject4}" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.08" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <!-- 搜索 + 计数 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <local:MyTextBox x:Name="TxtSearch" Grid.Column="0" Hint="搜索存档名..." VerticalAlignment="Center" />
                        <TextBlock x:Name="LabCount" Grid.Column="1" Text="共 0 个存档" FontSize="12"
                                   Foreground="{DynamicResource ColorBrushGray2}" VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>

                    <!-- 存档列表 -->
                    <ScrollViewer x:Name="ScrollSaves" MaxHeight="480" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanSaveList" />
                    </ScrollViewer>

                    <!-- 空状态 -->
                    <TextBlock x:Name="LabEmpty" Text="未找到匹配的存档配置" FontSize="13"
                               Foreground="{DynamicResource ColorBrushGray3}" HorizontalAlignment="Center"
                               Margin="0,12,0,0" Visibility="Visible" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
